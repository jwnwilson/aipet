{
    "compileOnSave": true,
    "compilerOptions": {
        "target": "ES6",
        "module": "ESNext",
        "sourceMap": false,
        "outDir": "./dist/server",
        "rootDir": "..",
        "strict": false,
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "allowJs": true,
        "moduleResolution": "bundler",
        "types": ["node"],
        "typeRoots": ["node_modules/@types"],
        "paths": {
            "@shared/*": ["../shared/*"]
        }
    },
    "include": ["src/*", "src/**/*.d.ts", "../shared/**/*.ts", "../shared/**/*.js"],
    "exclude": ["node_modules", "**/*.spec.js"]
}
