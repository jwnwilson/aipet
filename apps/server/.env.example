# Claude API key — required for bunny chat dialogue
ANTHROPIC_API_KEY=

# URL of the aipet_llm FastAPI inference service
# Set to http://localhost:8000 for local development
# Override with a hosted URL in production
AIPET_LLM_URL=http://localhost:8000

# Timeout in milliseconds for POST /infer calls to aipet_llm
# The server falls back to EXPLORE if the request exceeds this limit
AIPET_LLM_TIMEOUT_MS=10000

# Auth0 M2M credentials for authenticating calls to aipet_llm /infer
# Leave unset for local development (auth bypassed when CLIENT_ID is absent)
AUTH0_DOMAIN=
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_M2M_AUDIENCE=
